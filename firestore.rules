rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId));
    }
    
    function isParticipant(userIds) {
      return request.auth.uid in userIds;
    }

    // Profiles: Anyone auth can read, only owner can write
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // Likes: READ ONLY for involved users. Writes ONLY via API (Admin)
    match /likes/{likeId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid || 
        resource.data.toUserId == request.auth.uid
      );
      allow write: if false; // Production Hardening: Block client-side writes
    }
    
    // Matches: Only involved users can read. Writes ONLY via API (Admin)
    match /matches/{matchId} {
      allow read: if isAuthenticated() && isParticipant(resource.data.users);
      allow write: if false; // Production Hardening: Block client-side writes
    }
    
    // Messages: Only match participants can read. 
    // CREATE is also blocked from client to enforce server-side moderation and "Women First" logic.
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      // Updates only for marking as read by the recipient
      allow update: if isAuthenticated() && 
        resource.data.receiverId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      
      allow create, delete: if false; // Production Hardening: Enforce API for messaging
    }
    
    // Verification Requests: User creates, Admin reads/updates
    match /verificationRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false; 
    }

    // AI Logs: Read/Write only for admins (or internal only, set to false for client)
    match /ai_logs/{logId} {
      allow read, write: if false;
    }
  }
}
