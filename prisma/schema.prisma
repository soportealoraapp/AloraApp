generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// CORE DOMAIN
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          String    @default("user") // user, moderator, admin
  isActive      Boolean   @default(true)
  isBetaUser    Boolean   @default(false)
  betaInvitedBy String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  // Core Relations
  profile        Profile?
  sessions       Session[]
  sentMessages   Message[]       @relation("SentMessages")
  spotifyAccount SpotifyAccount?

  // Auditing
  auditLogs AuditLog[]

  // Matches
  matchesAsUser1 Match[] @relation("MatchUser1")
  matchesAsUser2 Match[] @relation("MatchUser2")

  // Interactions (Likes/Passes)
  sentInteractions     Interaction[] @relation("InteractionSender")
  receivedInteractions Interaction[] @relation("InteractionReceiver")

  // Relationships (v3.1)
  relationshipsAsPartner1 RelationshipContext[] @relation("RelPartner1")
  relationshipsAsPartner2 RelationshipContext[] @relation("RelPartner2")

  // Block/Report
  blockedUsers Block[] @relation("UserBlocker")

  // Notifications
  notifications          Notification[]
  notificationPreference NotificationPreference?
  dailyAnswers           DailyAnswer[]

  // Analytics
  analyticsEvents AnalyticsEvent[]

  // AI & Wellbeing (v3.x)
  aiCoachSessions  AiCoachSession[]
  wellbeingEvents  WellbeingEvent[]
  postDatingEvents PostDatingEvent[]
  cooldownState    CooldownState?
  closureArtifacts ClosureArtifact[]

  // v3.9.0 Moderation
  reportsSent     Report[] @relation("UserReporter")
  reportsReceived Report[] @relation("UserReported")
  blockedBy       Block[]  @relation("UserBlocked")

  // v4.x Push & Device
  pushTokens              PushToken[]
  deviceFingerprints      DeviceFingerprint[]
  verificationSubmissions VerificationSubmission[]
  userMemory              UserMemory?
  dateReflections         DateReflection[]
  quizResults             QuizResult[]
  profileVisitsGiven      ProfileVisit[]           @relation("ProfileVisitVisitor")
  profileVisitsReceived   ProfileVisit[]           @relation("ProfileVisitVisited")
  waitlistEntries         WaitlistEntry[]

  @@map("users")
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  displayName String?
  bio         String?
  age         Int?
  gender      String?
  photos      String[] // URL array

  // Preferences
  seeking   String?
  interests String[]
  values    String[]

  // Rich Profile Fields (user-editable)
  city          String?
  zodiacSign    String?
  education     String?
  smoking       String?
  drinking      String?
  children      String?
  religion      String?
  musicGenres   String[]
  status        String?
  personalGuide Json?

  // Relationship goals
  lookingFor      String? // casual, serious, friendship, networking
  connectionModes String[] @default(["dating"]) // dating, friendship

  // Privacy settings
  incognitoMode    Boolean @default(false)
  showMeInDiscover Boolean @default(true)
  verifiedOnly     Boolean @default(false)

  // Location (structured)
  cityId      String?
  countryCode String?
  stateCode   String?
  latitude    Float?
  longitude   Float?

  // Status
  isVerified            Boolean   @default(false)
  isCompleted           Boolean   @default(false) // Onboarding completion flag
  subscriptionStatus    String    @default("free") // free, plus
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  trustStatus           String    @default("clean") // clean, watchlist, banned
  reputationScore       Int       @default(100) // v3.9.0 Secret Score
  isShadowBanned        Boolean   @default(false) // v3.9.1 Shadow Moderation
  incomplete_media      Boolean   @default(false) // v3.9.2 Signup UX logic
  lastActiveAt          DateTime  @default(now())

  // Daily likes tracking
  dailyLikesUsed      Int      @default(0)
  dailyLikesResetAt   DateTime @default(now())
  superlikesRemaining Int      @default(3)

  // Boost tracking
  boostExpiresAt DateTime?
  lastBoostAt    DateTime?
  totalBoosts    Int       @default(0)

  // Travel mode
  travelModeEnabled Boolean   @default(false)
  travelCity        String?
  travelCountryCode String?
  travelLatitude    Float?
  travelLongitude   Float?
  travelStartedAt   DateTime?

  // Rewind
  lastSwipeId    String?
  lastSwipeAt    DateTime?
  rewindsUsed    Int       @default(0)
  rewindsResetAt DateTime  @default(now())

  // Streaks
  currentStreak        Int       @default(0)
  longestStreak        Int       @default(0)
  lastCheckInAt        DateTime?
  streakRewardsClaimed String[]  @default([])

  // Gamification
  badges Json @default("[]") // [{key, unlockedAt}]

  // Voice intro
  voiceIntro         String?
  voiceIntroDuration Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trustStatus])
  @@index([countryCode])
  @@index([lastActiveAt])
  @@index([trustStatus, incognitoMode, showMeInDiscover])
  @@map("profiles")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // Refresh token or session ID
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  isValid   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model Match {
  id String @id @default(uuid())

  user1Id String
  user1   User   @relation("MatchUser1", fields: [user1Id], references: [id])

  user2Id String
  user2   User   @relation("MatchUser2", fields: [user2Id], references: [id])

  score    Float   @default(0) // Compatibility Score
  isActive Boolean @default(true)

  // State
  stage  String @default("talking") // talking, dating, relationship, unmatched
  intent String @default("dating") // dating, friendship

  // Trust & Safety
  mutedUntil    DateTime?
  mutedByUserId String? // Which user initiated the mute
  hiddenBy      String[]  @default([])

  // Match Health
  healthScore     Int?
  healthUpdatedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete (Unmatch)

  messages Message[]

  // AI Context
  copilotContext CopilotContext?

  // v5.x Snapshots
  relationshipSnapshots RelationshipSnapshot[]

  @@unique([user1Id, user2Id, intent])
  @@index([user1Id])
  @@index([user2Id])
  @@map("matches")
}

model Message {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  content String
  type    String @default("text") // text, image, icebreaker, voice
  status  String @default("sent") // sent, delivered, read, flagged

  reactions Json @default("{}") // {userId: emoji}

  readAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([matchId])
  @@index([senderId])
  @@index([matchId, senderId])
  @@map("messages")
}

model Interaction {
  id String @id @default(uuid())

  fromUserId String
  fromUser   User   @relation("InteractionSender", fields: [fromUserId], references: [id], onDelete: Cascade)

  toUserId String
  toUser   User   @relation("InteractionReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  type   String // like, superlike, pass
  intent String @default("dating") // dating, friendship

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@unique([fromUserId, toUserId, intent])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([toUserId, type, deletedAt])
  @@map("interactions")
}

model SpotifyAccount {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  spotifyUserId         String
  displayName           String?
  refreshTokenEncrypted String
  topTracks             Json      @default("[]")
  topArtists            Json      @default("[]")
  playlistId            String?
  playlistUrl           String?
  lastSyncedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("spotify_accounts")
}

// -----------------------------------------------------------------------------
// AI / COPILOT DOMAIN
// -----------------------------------------------------------------------------

model CopilotContext {
  id      String @id @default(uuid())
  matchId String @unique
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Awareness
  summary            String?  @db.Text
  sentimentScore     Float?
  topicsDiscussed    String[]
  nextMoveSuggestion String?

  lastAnalyzedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events CopilotEvent[]

  @@map("copilot_context")
}

model CopilotEvent {
  id               String         @id @default(uuid())
  copilotContextId String
  context          CopilotContext @relation(fields: [copilotContextId], references: [id], onDelete: Cascade)

  eventType String // suggestion_given, intervention, nudge
  details   Json?

  createdAt DateTime @default(now())

  @@map("copilot_events")
}

model AiCoachSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages AiMessage[]

  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_coach_sessions")
}

model AiMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   AiCoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role     String // user, assistant, system
  content  String @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  @@map("ai_messages")
}

// -----------------------------------------------------------------------------
// RELATIONSHIP INTELLIGENCE (v3.1)
// -----------------------------------------------------------------------------

model RelationshipContext {
  id String @id @default(uuid())

  partner1Id String
  partner1   User   @relation("RelPartner1", fields: [partner1Id], references: [id])

  partner2Id String
  partner2   User   @relation("RelPartner2", fields: [partner2Id], references: [id])

  status    String   @default("active") // active, paused, ended
  startDate DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  notes     CommunicationNote[]
  conflicts ConflictReflection[]

  @@map("relationship_context")
}

model CommunicationNote {
  id             String              @id @default(uuid())
  relationshipId String
  relationship   RelationshipContext @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  content  String
  category String // appreciation, observation, request

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("communication_notes")
}

model ConflictReflection {
  id             String              @id @default(uuid())
  relationshipId String
  relationship   RelationshipContext @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  trigger    String
  myReaction String
  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conflict_reflections")
}

// -----------------------------------------------------------------------------
// WELLBEING & POST-DATING CARE (v3.2)
// -----------------------------------------------------------------------------

model WellbeingEvent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     String // fatigue_detected, ghosting_intervention, burnout_warning
  severity String // low, medium, high
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("wellbeing_events")
}

model PostDatingEvent {
  id      String  @id @default(uuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId String? // Optional reference to past match

  type  String // breakup, rejection, ghosted
  notes String?

  createdAt DateTime @default(now())

  @@map("post_dating_events")
}

model CooldownState {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive Boolean   @default(true)
  reason   String? // breakup_recovery, burnout
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cooldown_state")
}

model ClosureArtifact {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String // unsent_letter, voice_memo, reflection
  content   String  @db.Text
  isPrivate Boolean @default(true) // Always private by design usually

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@map("closure_artifacts")
}

// -----------------------------------------------------------------------------
// SYSTEM & INFRA
// -----------------------------------------------------------------------------

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String
  ipAddress String?
  details   Json?
  metadata  Json?

  timestamp DateTime @default(now())

  @@map("audit_logs")
}

model DailyQuestion {
  id          String        @id @default(uuid())
  question    String        @unique
  category    String
  isActive    Boolean       @default(true)
  activatedAt DateTime?
  createdAt   DateTime      @default(now())
  answers     DailyAnswer[]

  @@map("daily_questions")
}

model DailyAnswer {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  questionId String
  question   DailyQuestion @relation(fields: [questionId], references: [id])
  answer     String
  createdAt  DateTime      @default(now())

  @@unique([userId, questionId])
  @@index([userId])
  @@map("daily_answers")
}

model NotificationPreference {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches        Boolean @default(true)
  messages       Boolean @default(true)
  profileViews   Boolean @default(true)
  promotions     Boolean @default(false)
  dailyQuestion  Boolean @default(true)
  streakReminder Boolean @default(true)
  readReceipts   Boolean @default(true)
  notifications  Boolean @default(true)

  @@map("notification_preferences")
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String   @unique // userId_action or ip_action
  count     Int      @default(0)
  lastReset DateTime @default(now())

  @@map("rate_limits")
}

model IdempotencyKey {
  id             String @id @default(uuid())
  key            String
  userId         String
  action         String // e.g. 'chat_send', 'match_like'
  responseStatus Int?
  responseBody   Json?

  createdAt DateTime @default(now())

  @@unique([key, action])
  @@index([userId])
  @@index([createdAt])
  @@map("idempotency_keys")
}

model Block {
  id        String @id @default(uuid())
  blockerId String
  blocker   User   @relation("UserBlocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User   @relation("UserBlocked", fields: [blockedId], references: [id])

  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String // match, message, system
  title   String
  body    String
  data    Json? // deep link payload
  channel String @default("default") // notification channel for Android

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

model PushToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String
  platform String // android, ios, web
  deviceId String?
  lastSeen DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([token])
  @@index([userId])
  @@map("push_tokens")
}

model ProfileVisit {
  id        String   @id @default(uuid())
  visitorId String
  visitor   User     @relation("ProfileVisitVisitor", fields: [visitorId], references: [id], onDelete: Cascade)
  visitedId String
  visited   User     @relation("ProfileVisitVisited", fields: [visitedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([visitorId, createdAt])
  @@index([visitedId, createdAt])
  @@map("profile_visits")
}

model WaitlistEntry {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  region      String
  status      String    @default("waiting") // waiting, approved, expired
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@unique([userId, region])
  @@index([region, status])
  @@map("waitlist_entries")
}

model BetaCode {
  id        String    @id @default(uuid())
  code      String    @unique
  createdBy String
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  region    String?
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([code])
  @@index([active])
  @@map("beta_codes")
}

model AnalyticsEvent {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  event     String // signup, onboarding_complete, first_match, first_message, first_reply, daily_active
  metadata  Json?
  sessionId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("analytics_events")
}

model DeviceFingerprint {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceHash String // SHA256 of device characteristics
  os         String?
  browser    String?
  timezone   String?
  language   String?
  screenSize String?
  ipAddress  String?
  userAgent  String?

  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([userId, deviceHash])
  @@index([userId])
  @@index([deviceHash])
  @@map("device_fingerprints")
}

model VerificationSubmission {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  selfieUrl  String
  gesture    String? // smile, v_sign, thumbs_up, open_palm
  status     String    @default("pending") // pending, approved, rejected
  reason     String? // rejection reason
  reviewedBy String? // admin userId who reviewed
  reviewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@map("verification_submissions")
}

model Job {
  id          String    @id @default(uuid())
  type        String
  payload     Json?
  priority    Int       @default(3)
  status      String    @default("pending") // pending, processing, completed, failed, retrying
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  error       String?
  workerId    String?
  result      Json?
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority, scheduledAt])
  @@index([type, status])
  @@index([createdAt])
  @@map("jobs")
}

model Lock {
  id         String   @id @default(uuid())
  name       String   @unique
  owner      String
  acquiredAt DateTime @default(now())

  @@map("locks")
}

model UserMemory {
  id                     String  @id @default(uuid())
  userId                 String  @unique
  user                   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled                Boolean @default(false)
  communicationPrefs     String? // Encrypted JSON
  emotionalPatterns      String? // Encrypted JSON
  conversationTendencies String? // Encrypted JSON
  pacingStyle            String? // Encrypted JSON
  relationshipIntentions String? // Encrypted JSON
  loveLanguage           String? // Encrypted — inferred love language
  conflictStyle          String? // Encrypted — inferred conflict style
  opennessLevel          String? // Encrypted — openness to depth
  toleratedIntensity     String? // Encrypted — intensity tolerance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_memory")
}

model RelationshipSnapshot {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  emotionalDepth     Float
  reciprocity        Float
  consistency        Float
  responseBalance    Float
  conflictRisk       Float
  attachmentTrend    Float
  chemistryScore     Float
  vulnerabilityScore Float
  engagementLevel    Float

  generatedAt DateTime @default(now())

  @@index([matchId, generatedAt])
  @@map("relationship_snapshots")
}

model DateReflection {
  id           String  @id @default(uuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String?
  matchId      String?

  emotionalSafety Int // 1-5
  chemistry       Int // 1-5
  authenticity    Int // 1-5
  communication   Int // 1-5
  wouldSeeAgain   Boolean
  notes           String? // Encrypted
  aiAnalysis      String? // Encrypted JSON — AI analysis of date

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("date_reflections")
}

model QuizResult {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId    String
  answers   Json
  score     Int?
  archetype String?
  createdAt DateTime @default(now())

  @@unique([userId, quizId])
  @@map("quiz_results")
}

model Incident {
  id           String    @id @default(uuid())
  type         String // reconnect_spike, notification_failure, queue_deadlock, realtime_outage, ai_timeout, db_degradation
  severity     String // info, warning, critical
  source       String // websocket, queue, db, ai, push
  message      String
  details      Json?
  autoResolved Boolean   @default(false)
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@map("incidents")
}

model Report {
  id         String @id @default(uuid())
  reporterId String
  reporter   User   @relation("UserReporter", fields: [reporterId], references: [id])
  reportedId String
  reported   User   @relation("UserReported", fields: [reportedId], references: [id])

  reason    String
  details   String?
  status    String   @default("pending") // pending, reviewed, dismissed, resolved
  createdAt DateTime @default(now())

  @@index([reportedId])
  @@index([reporterId])
  @@map("reports")
}

// -----------------------------------------------------------------------------
// SPRINT 5 MODELS
// -----------------------------------------------------------------------------

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  profileId String
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
  @@index([userId])
  @@index([profileId])
  @@map("favorites")
}

model DailyPick {
  id        String   @id @default(uuid())
  userId    String
  profileId String
  reason    String
  score     Int      @default(0)
  date      DateTime @default(now())
  viewed    Boolean  @default(false)
  liked     Boolean?
  createdAt DateTime @default(now())

  @@unique([userId, profileId, date])
  @@index([userId, date])
  @@map("daily_picks")
}

model MatchFeedback {
  id        String   @id @default(uuid())
  matchId   String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([matchId])
  @@map("match_feedback")
}

model Referral {
  id          String    @id @default(uuid())
  referrerId  String
  referredId  String?
  code        String    @unique
  status      String    @default("pending")
  rewardType  String?
  rewardValue Int?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  maxUses     Int       @default(1)
  usesCount   Int       @default(0)

  @@index([referrerId])
  @@index([code])
  @@map("referrals")
}

model SuccessStory {
  id        String   @id @default(uuid())
  title     String
  story     String
  photoUrl  String?
  authorId  String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([approved])
  @@map("success_stories")
}

// ========== Experimentation Platform (v7) ==========

model Experiment {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  status      String  @default("draft") // draft, running, paused, completed
  metric      String  @default("activation_rate") // activation_rate, match_rate, d7_retention

  variants    ExperimentVariant[]
  assignments ExperimentAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("experiments")
}

model ExperimentVariant {
  id           String     @id @default(uuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  name         String // control, treatment_a, treatment_b...
  trafficPct   Float      @default(50) // 0-100

  assignments ExperimentAssignment[]

  @@unique([experimentId, name])
  @@index([experimentId])
  @@map("experiment_variants")
}

model ExperimentAssignment {
  id           String            @id @default(uuid())
  experimentId String
  experiment   Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  userId       String

  createdAt DateTime @default(now())

  @@unique([experimentId, userId])
  @@index([experimentId])
  @@index([variantId])
  @@index([userId])
  @@map("experiment_assignments")
}
